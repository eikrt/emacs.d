[[https://en.wikipedia.org/wiki/Sieve_of_Eratosthenes#Example]]
#+BEGIN_SRC python
   
def sieve_eratosthenes(n):
    is_prime = [True] * (n + 1)
    is_prime[0] = is_prime[1] = False 
    
    p = 2 
    
    while p**2 <= n:
        if is_prime[p]:
            for i in range(p**2, n+1, p):
                is_prime[i] = False
        p += 1
    primes = [i for i in range(2, n+1) if is_prime[i]]
    
    return primes

n = 65
